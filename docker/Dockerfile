ARG VALGRIND_REQUESTS_CROSS_TARGET=x86_64-unknown-linux-gnu
ARG VALGRIND_REQUESTS_CROSS_VALGRIND_VERSION=3.26.0

FROM ghcr.io/cross-rs/${VALGRIND_REQUESTS_CROSS_TARGET}:main
ARG DEBIAN_FRONTEND=noninteractive

ARG VALGRIND_REQUESTS_CROSS_VALGRIND_VERSION
COPY prepare_valgrind.sh /
RUN /prepare_valgrind.sh

ARG VALGRIND_REQUESTS_CROSS_VALGRIND_VERSION
ARG VALGRIND_REQUESTS_CROSS_TARGET
COPY build_valgrind.sh /
RUN /build_valgrind.sh

COPY cleanup_valgrind.sh /
RUN /cleanup_valgrind.sh

ARG VALGRIND_REQUESTS_CROSS_TARGET
COPY build_custom_image.sh linux-image.sh /
RUN /build_custom_image.sh

ARG VALGRIND_REQUESTS_CROSS_TARGET
ENV VALGRIND_REQUESTS_CROSS_TARGET=${VALGRIND_REQUESTS_CROSS_TARGET}
ENV VALGRIND_REQUESTS_CROSS_VALGRIND_DESTDIR="/target/valgrind/${VALGRIND_REQUESTS_CROSS_TARGET}"
ENV VALGRIND_REQUESTS_CROSS_VALGRIND_TEMPDIR="/valgrind/target"
